# RAG MCP 환경 설정 예시 (.env로 복사해서 사용)

# 데이터 루트 (색인 산출물·Qdrant·manifest 저장 위치)
RAG_DATA_DIR=./data

# Qdrant 저장 모드: "local"(path) 또는 "server"(url)
RAG_QDRANT_MODE=local
RAG_QDRANT_PATH=./data/qdrant
# RAG_QDRANT_URL=http://localhost:6333

# 기본 임베딩 모델: "kure" 또는 "bge_m3"
RAG_EMBEDDING_MODEL=kure

# 표 이미지 렌더 DPI
RAG_RENDER_DPI=200

# OCR: off | auto(기본) | force
# auto는 깨진 표(needs_image 청크)만 페이지 OCR로 보강한다.
# 스캔 PDF 문서 단위 hybrid는 아래 RAG_ODL_HYBRID를 켰을 때만 동작한다(기본 off).
RAG_OCR=auto
# 스캔 PDF 판정 임계: 페이지당 글자 수가 이 값 미만이면 빈약한 페이지로 본다(hybrid 후보 판단용)
RAG_OCR_MIN_CHARS=30
RAG_OCR_LANG=kor+eng
# 스캔 PDF 문서 단위 OpenDataLoader hybrid (off=페이지 OCR만; hybrid 서버 별도 기동)
# RAG_ODL_HYBRID=hancom-ai
# RAG_ODL_HYBRID_URL=http://127.0.0.1:5002

